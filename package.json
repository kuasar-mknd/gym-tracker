{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "format": "prettier --write \"resources/**/*.{js,vue,css}\" && ./vendor/bin/pint",
        "lint": "npm run lint:js && npm run lint:php",
        "lint:js": "prettier --check \"resources/**/*.{js,vue,css}\"",
        "lint:php": "./vendor/bin/phpstan analyze --memory-limit=2G",
        "test": "vitest run",
        "test:js": "vitest run",
        "prepare": "husky"
    },
    "lint-staged": {
        "resources/**/*.{js,vue,css}": "prettier --write",
        "**/*.php": "./vendor/bin/pint"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.3.18",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.2.2",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitest/coverage-v8": "^4.1.3",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "^10.5.0",
        "axios": "^1.15.1",
        "concurrently": "^9.0.1",
        "husky": "^9.1.7",
        "jsdom": "^29.0.2",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^16.3.2",
        "postcss": "^8.5.10",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.2.2",
        "vite": "^8.0.9",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.4",
        "vue": "^3.5.32",
        "workbox-precaching": "^7.4.0",
        "workbox-routing": "^7.4.0",
        "workbox-strategies": "^7.4.0",
        "workbox-window": "^7.4.0"
    },
    "dependencies": {
        "@sentry/vue": "^10.49.0",
        "chart.js": "^4.5.1",
        "dayjs": "^1.11.20",
        "lucide-vue-next": "^0.577.0",
        "radix-vue": "^1.9.17",
        "serialize-javascript": "^7.0.5",
        "vue-chartjs": "^5.3.3",
        "ziggy-js": "^2.6.2"
    },
    "overrides": {
        "serialize-javascript": "^7.0.5"
    },
    "pnpm": {
        "overrides": {
            "serialize-javascript": "^7.0.5"
        }
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-arm64-gnu": "^4.60.1"
    }
}
